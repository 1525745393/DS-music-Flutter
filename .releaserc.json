{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "flutter pub get",
        "prepareCmd": "sed -i \"s/^version: .*/version: ${nextRelease.version}/\" pubspec.yaml",
        "publishCmd": "flutter build apk --release --build-number=$GITHUB_RUN_NUMBER"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["pubspec.yaml", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "build/app/outputs/flutter-apk/app-release.apk",
            "label": "DS Player ${nextRelease.version}.apk"
          }
        ]
      }
    ]
  ]
}
